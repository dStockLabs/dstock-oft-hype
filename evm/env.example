# ------------------------------------------------------------
# DStockOFTUpgradeable / DStockOFTAdapter deployment scripts (Foundry)
# ------------------------------------------------------------
# DEPLOYER_PK=123...                # deployer private key (used by vm.startBroadcast)
# LZ_ENDPOINT=0x...                 # LayerZero EndpointV2
# LZ_DELEGATE=0x...                 # LayerZero delegate (also becomes owner)
#
# # DStockOFTUpgradeable (TransparentUpgradeableProxy + initialize)
# NAME=""
# SYMBOL=""
# ADMIN=0xYourMultisig...
# TREASURY=0xYourTreasury...        # optional; defaults to ADMIN if omitted
# PROXY_ADMIN_OWNER=0xYourMultisig...# optional; defaults to ADMIN if omitted
#
# # DStockOFTAdapter (existing ERC20 -> OFTAdapter)
# TOKEN=0xUnderlyingErc20...

